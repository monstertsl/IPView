# IPVIEW Backend Environment Variables
# Copy this file to .env and modify values for your environment

# Application
APP_NAME=IPVIEW
SECRET_KEY=change-me-in-production-use-64-char-random-hex-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ipview

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Encryption Key (32 bytes = 64 hex chars)
ENCRYPT_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# System Config Defaults
ONLINE_DAYS=7
OFFLINE_DAYS=15
CLEANUP_DAYS=30
LOGIN_FAIL_LIMIT=5
INACTIVE_DAYS_LIMIT=90
LOG_RETENTION_DAYS_LOGIN=90
LOG_RETENTION_DAYS_SCAN=30

# SNMP Defaults
SNMP_TIMEOUT=3
SNMP_RETRY=2
